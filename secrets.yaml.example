# FlyNow — Secrets Template
#
# Copy this file to secrets.yaml and fill in your values.
# secrets.yaml is git-ignored and must NEVER be committed.
#
# Most of these are configured via the HA config flow UI once the integration
# is installed. This file is for development/testing reference only.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Launch Location ───────────────────────────────────────────────────────────
# Coordinates of your primary launch site (Slovakia)
launch_latitude: 48.XXXX
launch_longitude: 17.XXXX
launch_site_name: "My Launch Site"

# ── Home Assistant ────────────────────────────────────────────────────────────
# Long-lived access token for local dev/testing (generate in HA profile)
ha_token: "eyJ..."
ha_url: "http://homeassistant.local:8123"

# ── Notification Contacts ─────────────────────────────────────────────────────
# Phone numbers for push notifications (HA Companion app device IDs)
crew_ha_device_id: "your_phone_device_id"
pilot_ha_device_id: "pilot_phone_device_id"

# ── Google Calendar ───────────────────────────────────────────────────────────
# OAuth credentials from Google Cloud Console
# Project: https://console.cloud.google.com/ → APIs & Services → Credentials
# Scopes needed: https://www.googleapis.com/auth/calendar.events
google_client_id: "XXXX.apps.googleusercontent.com"
google_client_secret: "GOCSPX-XXXX"
google_calendar_id: "primary"  # or a specific calendar ID

# ── WhatsApp via CallMeBot ────────────────────────────────────────────────────
# 1. Add +34 644 59 78 13 to your contacts as CallMeBot
# 2. Send "I allow callmebot to send me messages" via WhatsApp to that number
# 3. You'll receive your API key in response
callmebot_phone: "+421XXXXXXXXX"   # Your WhatsApp phone number (international format)
callmebot_api_key: "XXXXXXX"
pilot_callmebot_phone: "+421XXXXXXXXX"  # Pilot's WhatsApp number
pilot_callmebot_api_key: "XXXXXXX"

# ── Signal (Optional — v1.x) ─────────────────────────────────────────────────
# Only needed if using Signal instead of/in addition to WhatsApp
# Requires signal-cli running as a service or Docker container
signal_sender_phone: "+421XXXXXXXXX"
signal_group_id: "group.XXXX=="  # Base64 group ID from signal-cli
signal_cli_url: "http://localhost:8080"  # signal-cli REST API URL

# ── Open-Meteo ───────────────────────────────────────────────────────────────
# Open-Meteo is FREE with no API key required.
# No credentials needed here — just configure location above.
# API docs: https://open-meteo.com/en/docs
